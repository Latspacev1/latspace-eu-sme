# Copy to .env.local and fill in real values. Never commit .env.local.

# ──────────────────────────────────────────────────────────────────────────
# Reporting / VSME Narrative AI assistant (chat + write routes)
# ──────────────────────────────────────────────────────────────────────────

# AGENT_DISPATCH_MODE controls how /api/reporting/chat and /api/reporting/write
# run the agent:
#   "local"   — spawns agent-runner/runner.ts as a child process on this
#               machine. Required for local development since the Vercel
#               Sandbox doesn't exist outside Vercel infra.
#   "sandbox" — (default) creates a Vercel Sandbox per request. Used in prod.
AGENT_DISPATCH_MODE=local

# Anthropic API key — required for both modes. The agent calls Claude here.
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI key — required for both modes. Used by the RAG retriever for
# embedding queries against the CDP/VSME document index.
VOYAGE_API_KEY=pa-...

# ──────────────────────────────────────────────────────────────────────────
# Vercel Sandbox (production only — leave commented out for local dev)
# ──────────────────────────────────────────────────────────────────────────

# AGENT_RUNNER_TARBALL_URL=https://...public.blob.vercel-storage.com/...
# AGENT_RUNNER_SNAPSHOT_ID=snap_...
